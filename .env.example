# HTTP
HTTP_ADDR=:8080

# Storage
SQLITE_PATH=/app/data/app.db
ARTIFACT_ROOT=/app/artifacts/jobs

# Main reasoning/writing model
MAIN_MODEL=gemma4:e2b
MAIN_MODEL_BASE_URL=http://10.0.0.119:11434
MAIN_MODEL_TIMEOUT=1800s
MAIN_MODEL_MAX_RETRIES=2

# Embeddings model
EMBEDDING_MODEL=embeddinggemma:300m
EMBEDDING_MODEL_BASE_URL=http://10.0.0.119:11434
EMBEDDING_MODEL_TIMEOUT=300s
EMBEDDING_MODEL_MAX_RETRIES=2

# Translation model
TRANSLATE_MODEL=translategemma:4b
TRANSLATE_MODEL_BASE_URL=http://10.0.0.119:11434
TRANSLATE_MODEL_TIMEOUT=1800s
TRANSLATE_MODEL_MAX_RETRIES=2

# Retry behavior
MODEL_RETRY_BACKOFF=10s

# Tooling
FFMPEG_BIN=ffmpeg
YTDLP_BIN=yt-dlp
WHISPER_CPP_BIN=/opt/whisper/bin/whisper-cli
WHISPER_MODEL_PATH=/opt/whisper/models/ggml-base.bin
TRANSCRIPT_FALLBACK_PATH=

# Feature flags and auth
ENABLE_TRANSLATION=false
ADMIN_SESSION_TTL=72h
ADMIN_COOKIE_NAME=vtb_admin_session

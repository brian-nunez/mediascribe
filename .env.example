# HTTP
HTTP_ADDR=:8080

# Storage
SQLITE_PATH=/app/data/app.db
ARTIFACT_ROOT=/app/artifacts/jobs

# Main reasoning/writing model
MAIN_MODEL=gpt-oss
MAIN_MODEL_BASE_URL=http://host.docker.internal:11434
MAIN_MODEL_TIMEOUT=1800s
MAIN_MODEL_MAX_RETRIES=2

# Embeddings model
EMBEDDING_MODEL=embeddinggemma
EMBEDDING_MODEL_BASE_URL=http://host.docker.internal:11435
EMBEDDING_MODEL_TIMEOUT=300s
EMBEDDING_MODEL_MAX_RETRIES=2

# Translation model
TRANSLATE_MODEL=translategemma
TRANSLATE_MODEL_BASE_URL=http://host.docker.internal:11436
TRANSLATE_MODEL_TIMEOUT=1800s
TRANSLATE_MODEL_MAX_RETRIES=2

# Retry behavior
MODEL_RETRY_BACKOFF=10s

# Tooling
FFMPEG_BIN=ffmpeg
YTDLP_BIN=yt-dlp
WHISPER_CPP_BIN=/app/deps/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL_PATH=/app/deps/whisper.cpp/models/ggml-base.bin
TRANSCRIPT_FALLBACK_PATH=

# Feature flags and auth
ENABLE_TRANSLATION=false
ADMIN_SESSION_TTL=72h
ADMIN_COOKIE_NAME=vtb_admin_session

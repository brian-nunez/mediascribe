{
  "name": "MediaScribe",
  "short_name": "MediaScribe",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#111111",
  "theme_color": "#111111",
  "description": "MediaScribe turns technical video content into structured engineering blogs.",
